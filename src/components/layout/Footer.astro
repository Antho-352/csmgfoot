---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-black text-white">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Column 1: Logo & Description -->
      <div>
        <a href="/" class="flex items-center gap-1 text-2xl font-heading tracking-wider mb-4">
          <span class="text-white">CSMG</span>
          <span class="text-brand-green">FOOT</span>
        </a>
        <p class="text-gray-400 mb-4">
          Creative Sport Media Group — L'agence spécialisée dans l'accompagnement des clubs de football en France.
        </p>
        <p class="text-brand-green font-semibold">
          🇫🇷 France entière
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h3 class="font-heading text-lg mb-4 uppercase tracking-wide">Navigation</h3>
        <ul class="space-y-2">
          <li>
            <a href="/communication" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Communication
            </a>
          </li>
          <li>
            <a href="/recrutement" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Recrutement
            </a>
          </li>
          <li>
            <a href="/formation" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Formation
            </a>
          </li>
          <li>
            <a href="/notre-agence" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Notre agence
            </a>
          </li>
          <li>
            <a href="/realisations" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Réalisations
            </a>
          </li>
          <li>
            <a href="/blog" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Blog
            </a>
          </li>
          <li>
            <a href="/contact" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Contact & Legal -->
      <div>
        <h3 class="font-heading text-lg mb-4 uppercase tracking-wide">Contact</h3>
        <ul class="space-y-2 mb-6">
          <li>
            <a href="mailto:contact@csmgfoot.fr" class="text-gray-400 hover:text-brand-green transition-colors duration-200">
              contact@csmgfoot.fr
            </a>
          </li>
          <li class="text-gray-400">
            Réponse sous 24h ouvrées
          </li>
        </ul>
        
        <h4 class="font-heading text-sm mb-2 uppercase tracking-wide">Légal</h4>
        <ul class="space-y-2">
          <li>
            <a href="/mentions-legales" class="text-gray-400 hover:text-brand-green transition-colors duration-200 text-sm">
              Mentions légales
            </a>
          </li>
          <li>
            <a href="/politique-confidentialite" class="text-gray-400 hover:text-brand-green transition-colors duration-200 text-sm">
              Politique de confidentialité
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-brand-green/20">
    <div class="container-custom py-6">
      <p class="text-gray-400 text-sm text-center">
        © {currentYear} Creative Sport Media Group — Tous droits réservés
      </p>
    </div>
  </div>
</footer>
