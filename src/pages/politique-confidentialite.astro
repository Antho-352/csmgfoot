---
import PageLayout from '../layouts/PageLayout.astro';

const seo = {
  title: 'Politique de confidentialité | CSMG Foot',
  description: "Politique de confidentialité et RGPD du site CSMG Foot, agence spécialisée football en France.",
  image: '/og-default.jpg',
};
---

<PageLayout {...seo}>
  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto">
      <h1 class="font-heading mb-6">Politique de confidentialité</h1>
      <p class="text-gray-700 mb-4">CSMG Foot s'engage à respecter la confidentialité des données personnelles conformément au RGPD.</p>
      <ul class="list-disc pl-6 text-gray-700 mb-6">
        <li>Aucune donnée personnelle n'est collectée sans consentement.</li>
        <li>Les données des formulaires sont utilisées uniquement pour répondre aux demandes.</li>
        <li>Vous pouvez demander la suppression de vos données à tout moment.</li>
        <li>Aucune donnée n'est transmise à des tiers.</li>
        <li>Pour toute question, contactez : contact@csmgfoot.fr</li>
      </ul>
      <p class="text-gray-700 mb-4">Pour toute demande relative à vos données, contactez-nous à l'adresse indiquée ci-dessus.</p>
    </div>
  </section>
</PageLayout>
