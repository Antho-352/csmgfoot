---
export const prerender = false;
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getPostBySlug, getPostsByCategory } from "../../lib/wordpress";

const { slug } = Astro.params;
const post = await getPostBySlug(slug);
const category = post?._embedded?.["wp:term"]?.[0]?.[0];
const related = category ? await getPostsByCategory(category.id, 1, 3) : [];

const seo = {
  title: `${post?.title?.rendered || "Article"} | CSMG Foot`,
  description: post?.excerpt?.rendered
    ? post.excerpt.rendered.replace(/<[^>]+>/g, "")
    : "",
  image:
    post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url || "/og-default.jpg",
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post?.title?.rendered || "",
    datePublished: post?.date || "",
    author: {
      "@type": "Person",
      name: "CSMG Foot",
    },
    articleSection: category?.name || "",
    image:
      post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
      "/og-default.jpg",
    url: `https://csmgfoot.fr/blog/${slug}`,
  },
};
---

<BlogLayout {...seo}>
  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto">
      <nav class="mb-6 text-sm text-gray-500">
        <a href="/">Accueil</a> &rarr; <a href="/blog">Blog</a> &rarr; <span
          class="text-brand-green">{post?.title?.rendered}</span
        >
      </nav>
      <span
        class="inline-block bg-brand-green text-white rounded-full px-3 py-1 text-xs font-semibold mb-2"
        >{category?.name || "Article"}</span
      >
      <h1
        class="font-heading mb-4"
        style="font-size: clamp(2.5rem, 5vw, 4rem);"
      >
        {post?.title?.rendered}
      </h1>
      <div class="mb-6">
        <img
          src={post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
            "/og-default.jpg"}
          alt={post?._embedded?.["wp:featuredmedia"]?.[0]?.alt_text ||
            post?.title?.rendered}
          class="img-bw rounded-xl w-full max-w-2xl mx-auto"
        />
      </div>
      <div
        class="prose prose-lg max-w-2xl mx-auto mb-8"
        set:html={post?.content?.rendered}
      >
      </div>
      <!-- Articles similaires -->
      {
        related.length > 0 && (
          <div class="mt-12">
            <h2 class="font-heading text-brand-black mb-4">
              Articles similaires
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {related.map((rel) => (
                <a
                  href={`/blog/${rel.slug}`}
                  class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm fade-in-up"
                >
                  <img
                    src={
                      rel._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
                      "/og-default.jpg"
                    }
                    alt={
                      rel._embedded?.["wp:featuredmedia"]?.[0]?.alt_text ||
                      rel.title.rendered
                    }
                    class="img-bw rounded-xl w-full h-24 object-cover mb-2"
                  />
                  <span class="inline-block bg-brand-green text-white rounded-full px-2 py-1 text-xs font-semibold mb-2">
                    {rel._embedded?.["wp:term"]?.[0]?.[0]?.name || "Article"}
                  </span>
                  <h3 class="font-heading text-base mb-1">
                    {rel.title.rendered}
                  </h3>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</BlogLayout>
