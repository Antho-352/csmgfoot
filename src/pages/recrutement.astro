---
import PageLayout from "../layouts/PageLayout.astro";
import pricingData from "../data/pricing.json";

const recrutementPricing =
  (pricingData as any[]).find((p) => p.type === "recrutement")?.services || [];
const pricingMap: Record<string, any> = {
  recherche_ponctuelle: recrutementPricing.find(
    (s: any) => s.name === "Recherche ponctuelle"
  ),
  transfert_complet: recrutementPricing.find(
    (s: any) => s.name === "Accompagnement transfert"
  ),
  partenariat_saison: recrutementPricing.find(
    (s: any) => s.name === "Partenariat saison"
  ),
};

const seo = {
  title: "Recrutement | CSMG Foot",
  description:
    "Recherche de profils, accompagnement de transferts, partenariat saison — CSMG accompagne les clubs de football français dans leur recrutement.",
  image: "/og-default.jpg",
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Recrutement",
    provider: {
      "@type": "Organization",
      name: "CSMG Foot",
    },
    areaServed: "France entière",
  },
};

const prestations = [
  {
    key: "recherche_ponctuelle",
    title: "Recherche ponctuelle",
    description:
      "Vous avez un poste \u00e0 pourvoir, une fen\u00eatre de transfert qui approche, un besoin urgent. On active notre r\u00e9seau national, on analyse les profils disponibles et on vous pr\u00e9sente une s\u00e9lection cibl\u00e9e \u2014 rapidement.",
    icon: "\uD83D\uDD0D",
    details: [
      {
        label: "Inclus",
        value:
          "D\u00e9finition du profil, sourcing, pr\u00e9sentation de 3 \u00e0 5 candidats qualifi\u00e9s",
      },
      { label: "D\u00e9lai", value: "7 \u00e0 14 jours" },
      { label: "Tarif", value: "500 \u20ac \u2014 1\u202f500 \u20ac HT" },
    ],
  },
  {
    key: "transfert_complet",
    title: "Accompagnement transfert complet",
    description:
      "De l'identification du profil jusqu'\u00e0 l'int\u00e9gration dans le club. Nous g\u00e9rons les \u00e9changes avec le joueur et son entourage, les formalit\u00e9s administratives FFF, et assurons un suivi post-recrutement sur 3 mois.",
    icon: "\uD83E\uDD1D",
    details: [
      {
        label: "Inclus",
        value: "Sourcing + n\u00e9gociation + administratif FFF + suivi 3 mois",
      },
      {
        label: "Tarif",
        value: "1\u202f000 \u20ac \u2014 3\u202f500 \u20ac HT",
      },
    ],
  },
  {
    key: "partenariat_saison",
    title: "Partenariat recrutement saison",
    description:
      "Un contrat de recrutement sur toute la saison sportive. CSMG devient votre cellule recrutement externalis\u00e9e\u00a0: mercato d'\u00e9t\u00e9, mercato d'hiver, anticipation des d\u00e9parts \u2014 on g\u00e8re l'ensemble de vos besoins en profils.",
    icon: "\uD83C\uDFC6",
    details: [
      {
        label: "Inclus",
        value:
          "Recrutements illimit\u00e9s sur la dur\u00e9e du contrat, reporting mensuel",
      },
      { label: "Dur\u00e9e", value: "1 saison sportive compl\u00e8te" },
      {
        label: "Tarif",
        value: "2\u202f000 \u20ac \u2014 6\u202f000 \u20ac HT",
      },
    ],
  },
];
---

<PageLayout {...seo}>
  <section class="section-padding bg-brand-black text-white">
    <div class="container-custom">
      <h1
        class="font-heading mb-6"
        style="font-size: clamp(2.5rem, 5vw, 4rem);"
      >
        Recrutement
      </h1>
      <p class="text-lg mb-8">
        Le bon joueur, au bon poste, au bon moment. CSMG accompagne les clubs de
        football français dans leurs recherches de profils et leurs transferts —
        de la définition du besoin jusqu'à la signature.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-custom">
      <h2
        class="font-heading text-brand-black mb-8"
        style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);"
      >
        Nos prestations
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          prestations.map((p) => (
            <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm hover:shadow-xl transition-all duration-300 fade-in-up flex flex-col">
              <div class="mb-4">
                <div class="w-10 h-10 rounded-full bg-brand-green/10 flex items-center justify-center">
                  <span class="text-2xl">{p.icon}</span>
                </div>
              </div>
              <h3 class="font-heading text-lg mb-2">{p.title}</h3>
              <p class="text-gray-600 mb-4 text-sm flex-1">{p.description}</p>
              <ul class="space-y-1">
                {p.details.map((d) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="font-semibold text-brand-black min-w-[60px]">
                      {d.label} :
                    </span>
                    <span>{d.value}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <h2 class="font-heading text-brand-black mb-6">Notre processus</h2>
      <div class="flex flex-col md:flex-row gap-8">
        <div class="flex-1 bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-heading text-brand-green mb-2">Brief</h3>
          <p class="text-gray-600">
            On commence par comprendre votre club : votre système de jeu, votre
            niveau, votre budget, vos contraintes. Le profil recherché se
            définit ensemble — pas sur une fiche de poste générique.
          </p>
        </div>
        <div class="flex-1 bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-heading text-brand-green mb-2">Sourcing</h3>
          <p class="text-gray-600">
            Activation de notre réseau de joueurs libres, agents et clubs
            partenaires. Recherche active sur les bases de données disponibles.
            Chaque profil est vérifié avant d'être présenté.
          </p>
        </div>
        <div class="flex-1 bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-heading text-brand-green mb-2">Sélection</h3>
          <p class="text-gray-600">
            Présentation des profils retenus avec analyse détaillée : niveau,
            disponibilité, prétentions, vidéos si disponibles. Vous choisissez,
            on organise les contacts.
          </p>
        </div>
        <div class="flex-1 bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-heading text-brand-green mb-2">Transfert</h3>
          <p class="text-gray-600">
            Accompagnement des négociations, gestion des formalités
            administratives FFF, signature. Suivi post-recrutement inclus pour
            s'assurer de la bonne intégration.
          </p>
        </div>
      </div>
      <div class="mt-12 bg-brand-black rounded-2xl p-8 text-center">
        <h3
          class="font-heading text-white mb-3"
          style="font-size: clamp(1.3rem, 2.5vw, 1.8rem);"
        >
          Un poste à pourvoir ? On s'en occupe.
        </h3>
        <p class="text-gray-300 mb-6">
          Dites-nous ce que vous cherchez — on vous répond sous 24h avec une
          première approche.
        </p>
        <a href="/devis" class="btn-primary inline-block">Simuler mon devis →</a
        >
      </div>
    </div>
  </section>
</PageLayout>
