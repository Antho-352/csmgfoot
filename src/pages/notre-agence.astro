---
import PageLayout from '../layouts/PageLayout.astro';
import team from '../data/team.json';

const seo = {
  title: 'Notre agence | CSMG Foot',
  description: "Découvrez l'équipe CSMG Foot, agence nouvelle génération née du terrain, passionnée, innovante, proche des clubs.",
  image: '/og-default.jpg',
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CSMG Foot",
    "url": "https://csmgfoot.fr",
    "logo": "https://csmgfoot.fr/favicon.svg",
    "description": "Agence spécialisée dans l'accompagnement des clubs de football français.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "FR"
    },
    "areaServed": "France entière"
  }
};

const valeurs = [
  { title: 'Passion', description: 'Animés par le football, nous vivons chaque projet avec engagement.' },
  { title: 'Innovation', description: 'Méthodes et outils digitaux pour des solutions modernes.' },
  { title: 'Proximité', description: 'Relation directe, écoute et accompagnement sur-mesure.' },
  { title: 'Résultats', description: 'Objectifs clairs, reporting transparent, suivi régulier.' },
];
---

<PageLayout {...seo}>
  <section class="section-padding bg-brand-black text-white">
    <div class="container-custom">
      <h1 class="font-heading mb-6" style="font-size: clamp(2.5rem, 5vw, 4rem);">Une agence née du terrain</h1>
      <p class="text-lg mb-8">CSMG Foot est née d'un constat simple : les clubs de football, quelle que soit leur taille, méritent un accompagnement professionnel pour se développer.</p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="font-heading text-brand-black mb-8" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Nos valeurs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {valeurs.map((v) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200 fade-in-up">
            <h3 class="font-heading text-brand-green mb-2">{v.title}</h3>
            <p class="text-gray-600">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <h2 class="font-heading text-brand-black mb-8">L'équipe</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map((member) => (
          <div class="bg-brand-black rounded-2xl p-6 flex flex-col items-center text-white fade-in-up">
            <!-- SVG Initiales -->
            <svg width="64" height="64" class="mb-4" viewBox="0 0 64 64" fill="none">
              <rect width="64" height="64" rx="16" fill="#0a0a0a" />
              <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" font-size="28" font-family="Bebas Neue, sans-serif" fill="#16a34a">{member.initials}</text>
            </svg>
            <h3 class="font-heading text-lg mb-2">{member.name}</h3>
            <p class="text-brand-green font-semibold mb-1">{member.role}</p>
            <p class="text-gray-400 text-sm text-center">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto">
      <h2 class="font-heading text-brand-black mb-6">Notre vision</h2>
      <p class="text-gray-700 text-lg">Nous croyons en un football français plus structuré, plus digital, plus ambitieux. Notre mission : accompagner les clubs dans leur développement, leur image et leur professionnalisation.</p>
    </div>
  </section>
</PageLayout>
