---
import PageLayout from '../layouts/PageLayout.astro';
import team from '../data/team.json';

const seo = {
  title: 'Notre agence | CSMG Foot',
  description: "Découvrez l'équipe CSMG Foot, agence nouvelle génération née du terrain, passionnée, innovante, proche des clubs.",
  image: '/og-default.jpg',
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CSMG Foot",
    "url": "https://csmgfoot.fr",
    "logo": "https://csmgfoot.fr/favicon.svg",
    "description": "Agence spécialisée dans l'accompagnement des clubs de football français.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "FR"
    },
    "areaServed": "France entière"
  }
};

const valeurs = [
  { title: 'Passion', description: "Le football n'est pas juste notre secteur d'activité. C'est notre point de départ, notre filtre, notre moteur sur chaque projet." },
  { title: 'Innovation', description: "On apporte au football amateur les méthodes et les outils qui étaient jusqu'ici réservés aux clubs professionnels." },
  { title: 'Proximité', description: "Un interlocuteur direct, des réponses rapides, une vraie relation de travail. Pas un ticket de support, une vraie conversation." },
  { title: 'Résultats', description: "Pas de promesses vagues. Des objectifs définis ensemble, des indicateurs clairs, un suivi transparent." },
];
---

<PageLayout {...seo}>
  <!-- HERO -->
  <section class="section-padding bg-brand-black text-white">
    <div class="container-custom">
      <h1 class="font-heading mb-6" style="font-size: clamp(2.5rem, 5vw, 4rem);">Une agence née du terrain</h1>
      <p class="text-lg mb-8">CSMG est née d'un constat simple : les clubs de football, quelle que soit leur taille, méritent un accompagnement professionnel pour se développer. On est là pour combler cet écart.</p>
    </div>
  </section>

  <!-- NOTRE HISTOIRE -->
  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto">
      <h2 class="font-heading text-brand-black mb-8" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Notre histoire</h2>
      <div class="space-y-6 text-gray-700 text-lg leading-relaxed">
        <p>Fondée par des passionnés du football français ayant évolué dans le milieu professionnel et semi-professionnel, Creative Sport Media Group est une agence digitale-native dédiée aux structures footballistiques.</p>
        <p>Notre conviction : un club bien accompagné communique mieux, recrute mieux, forme mieux. Et au final, il grandit — sur le terrain comme en dehors.</p>
        <p>On ne travaille qu'avec des clubs, des associations et des entreprises du secteur football. Pas de dispersion, pas de généralisme. C'est notre force.</p>
      </div>
    </div>
  </section>

  <!-- NOS VALEURS -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <h2 class="font-heading text-brand-black mb-8" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Nos valeurs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {valeurs.map((v) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200 fade-in-up">
            <h3 class="font-heading text-brand-green mb-2">{v.title}</h3>
            <p class="text-gray-600">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- L'ÉQUIPE -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="font-heading text-brand-black mb-8">L'équipe</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map((member) => (
          <div class="bg-brand-black rounded-2xl p-6 flex flex-col items-center text-white fade-in-up">
            <!-- Initiales SVG -->
            <svg width="64" height="64" class="mb-4" viewBox="0 0 64 64" fill="none">
              <rect width="64" height="64" rx="16" fill="#0a0a0a" />
              <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" font-size="28" font-family="Bebas Neue, sans-serif" fill="#16a34a">{member.initials}</text>
            </svg>
            <h3 class="font-heading text-lg mb-1 text-center">{member.name}</h3>
            <p class="text-brand-green font-semibold mb-3 text-sm text-center">{member.role}</p>
            <p class="text-gray-400 text-sm text-center">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NOTRE VISION -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom max-w-3xl mx-auto">
      <h2 class="font-heading text-brand-black mb-6">Notre vision</h2>
      <div class="space-y-4 text-gray-700 text-lg leading-relaxed">
        <p>Le football français compte des milliers de clubs qui font vivre des centaines de milliers de licenciés. La grande majorité n'a pas les ressources d'un club professionnel — mais elle a les mêmes besoins : communiquer, recruter, progresser.</p>
        <p>CSMG existe pour rendre accessible ce niveau d'accompagnement. Pas pour les 40 clubs professionnels français. Pour les autres.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-brand-black">
    <div class="container-custom max-w-2xl mx-auto text-center">
      <h2 class="font-heading text-white mb-4" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Travaillons ensemble.</h2>
      <p class="text-gray-300 text-lg mb-8">Vous avez un projet pour votre club ? On vous répond sous 24h.</p>
      <a href="/contact" class="btn-primary inline-block">Nous contacter →</a>
    </div>
  </section>
</PageLayout>
