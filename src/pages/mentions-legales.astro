---
import PageLayout from '../layouts/PageLayout.astro';

const seo = {
  title: 'Mentions légales | CSMG Foot',
  description: "Mentions légales du site CSMG Foot, agence spécialisée football en France.",
  image: '/og-default.jpg',
};
---

<PageLayout {...seo}>
  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto">
      <h1 class="font-heading mb-6">Mentions légales</h1>
      <p class="text-gray-700 mb-4">Conformément à la loi n°2004-575 du 21 juin 2004 pour la confiance dans l'économie numérique, voici les informations légales du site :</p>
      <ul class="list-disc pl-6 text-gray-700 mb-6">
        <li>Éditeur : Creative Sport Media Group</li>
        <li>Adresse : France entière</li>
        <li>Email : contact@csmgfoot.fr</li>
        <li>Hébergement : OVH Kimsufi, France</li>
        <li>Directeur de publication : Maxime Delcourt</li>
      </ul>
      <p class="text-gray-700 mb-4">Le site ne collecte aucune donnée personnelle sans consentement explicite. Les formulaires sont soumis à la politique de confidentialité.</p>
      <p class="text-gray-700 mb-4">Pour toute demande, contactez-nous à l'adresse indiquée ci-dessus.</p>
    </div>
  </section>
</PageLayout>
