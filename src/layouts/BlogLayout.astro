---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
  noindex?: boolean;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header />
  <main class="bg-white">
    <slot />
  </main>
  <Footer />
</BaseLayout>
