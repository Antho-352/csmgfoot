Options -Indexes
DirectoryIndex index.html index.php

RewriteEngine On

# ── 1. Fix cPanel : supprime /index.php fantôme ──────────────────────────────
# (seulement si index.php est dans la requête visible, pas pour le vrai WP)
RewriteCond %{THE_REQUEST} \s/((?!blog/).*?)index\.php[\s?]
RewriteRule ^ /%1 [R=301,L]

# ── 2. WordPress à la racine → rediriger vers /blog/ ─────────────────────────
# On redirige tout ce qui ressemble à du WordPress vers le sous-dossier /blog
RewriteCond %{REQUEST_URI} ^/(wp-login\.php|wp-admin|wp-includes|wp-content|xmlrpc\.php) [NC]
RewriteCond %{REQUEST_URI} !^/blog/
RewriteRule ^(.*)$ /blog/$1 [R=301,L]

# ── 3. WordPress : TOUT /blog → Apache/WP directement (son propre .htaccess) ─
RewriteRule ^blog(/.*)?$ - [L]

# ── 4. Fichiers statiques existants → servis directement ─────────────────────
# (_astro/, logo.svg, favicon.ico, robots.txt, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── 5. Dossiers avec index.html → servi directement (pages Astro statiques) ──
# /             → public_html/index.html
# /notre-agence/ → public_html/notre-agence/index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}index.html -f
RewriteRule ^(.*)$ /$1index.html [L]

# ── 6. Reste → Node.js Astro SSR (routes dynamiques du blog /blog/*) ──────────
RewriteRule ^(.*)$ http://127.0.0.1:3862/$1 [P,L]
