Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# ── 1. Fix cPanel : supprime /index.php fantôme ──────────────────────────────
RewriteCond %{THE_REQUEST} \s/(.*)index\.php[\s?]
RewriteRule ^ /%1 [R=301,L]

# ── 2. WordPress : TOUT /blog → servi par Apache/WP directement ──────────────
RewriteRule ^blog(/.*)?$ - [L]

# ── 3. Fichiers statiques existants → servis directement ─────────────────────
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── 4. Dossiers avec index.html → servi directement ──────────────────────────
# Ex: /notre-agence/ → public_html/notre-agence/index.html
# Ex: /             → public_html/index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}index.html -f
RewriteRule ^(.*)$ /$1index.html [L]

# ── 5. Reste → Node.js Astro SSR (uniquement les routes dynamiques) ───────────
RewriteRule ^(.*)$ http://127.0.0.1:3862/$1 [P,L]
