Options -Indexes

RewriteEngine On

# ── CORRIGER LE QUIRK cPanel : /index.php → / ────────────────────────────────
RewriteCond %{THE_REQUEST} \s/(.*)index\.php[\s?]
RewriteRule ^ /%1 [R=301,L]

# ── PROTÉGER WORDPRESS (/blog) ────────────────────────────────────────────────
RewriteRule ^blog(/.*)?$ - [L]

# ── SI UN DOSSIER CONTIENT UN index.html → LE SERVIR DIRECTEMENT ─────────────
# Ex: / → index.html, /communication/ → communication/index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*[^/])?/?$ %{REQUEST_FILENAME}/index.html [L]

# ── FICHIERS STATIQUES SERVIS DIRECTEMENT ────────────────────────────────────
# (_astro/, favicon.ico, robots.txt, sitemap.xml, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── TOUT LE RESTE → PROXY VERS NODE.JS (routes SSR: /blog/, /blog/slug) ──────
RewriteRule ^(.*)$ http://127.0.0.1:3862/$1 [P,L]
