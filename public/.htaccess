Options -Indexes

RewriteEngine On

# ── CORRIGER LE QUIRK cPanel : /index.php → / ────────────────────────────────
# cPanel tente de servir index.php comme DirectoryIndex — on le redirige vers /
RewriteCond %{THE_REQUEST} \s/(.*)index\.php[\s?]
RewriteRule ^ /%1 [R=301,L]

# ── PROTÉGER WORDPRESS (/blog) ────────────────────────────────────────────────
RewriteRule ^blog(/.*)?$ - [L]

# ── SERVIR LES FICHIERS STATIQUES DIRECTEMENT ────────────────────────────────
# _astro/, favicon.ico, robots.txt, sitemap.xml, og-default.jpg, etc.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── TOUT LE RESTE → PROXY VERS NODE.JS (port 3862) ───────────────────────────
# / → homepage Astro SSR
# /blog → liste des articles (WP temps réel)
# /blog/mon-article → article SSR
# /communication → page communication
RewriteRule ^(.*)$ http://127.0.0.1:3862/$1 [P,L]
